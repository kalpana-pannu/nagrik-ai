// NAGRIK AI - SW-420 Vibration Sensor
// VCC -> 3.3V | GND -> GND | DO -> GPIO27

#define VIBRATION_PIN 27

void setup() {
  Serial.begin(115200);
  pinMode(VIBRATION_PIN, INPUT);
  Serial.println("NAGRIK AI - Vibration Sensor Ready");
}

void loop() {
  int state = digitalRead(VIBRATION_PIN);
  if (state == HIGH) {
    Serial.println("VIBRATION DETECTED - Possible road damage/pothole impact");
  } else {
    Serial.println("Road Stable - No vibration");
  }
  delay(500);
}
